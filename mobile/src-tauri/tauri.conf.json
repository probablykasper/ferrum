{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Ferrum",
	"identifier": "space.kasper.ferrum",
	"build": {
		"beforeDevCommand": "npm run dev:web",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build:web",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "Ferrum",
				"width": 800,
				"height": 600
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
