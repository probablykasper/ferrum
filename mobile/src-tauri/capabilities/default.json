{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"dialog:default",
		"fs:default",
		{
			"identifier": "fs:read-files",
			"allow": ["**"]
		},
		"store:default",
		"safe-area-insets-css:default",
		"android-fs:default",
		"os:default"
	]
}
